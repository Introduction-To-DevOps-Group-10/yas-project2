pipeline {
  agent any

  options {
    disableConcurrentBuilds()
    timestamps()
  }

  environment {
    DOCKERHUB_NAMESPACE = 'tunas106'
    DOCKERHUB_CREDENTIALS = 'dockerhub-credentials'

    GITOPS_CREDENTIALS = 'github-token'
    GITOPS_REPO = 'github.com/TUNAS106/yas-gitops.git'
    GITOPS_BRANCH = 'main'
    GITOPS_FILE = 'argocd/applications/yas-dev.yaml'
  }

  stages {
    stage('Checkout Source') {
      steps {
        checkout scm

        sh 'git fetch --all --prune || true'

        script {
          env.SHORT_COMMIT = sh(
            script: 'git rev-parse --short=7 HEAD',
            returnStdout: true
          ).trim()

          echo "Current dev image tag: ${env.SHORT_COMMIT}"
        }
      }
    }

    stage('Detect Changed Services') {
      steps {
        script {
          def serviceConfig = [
            'cart'          : [dir: 'cart',           type: 'java', image: 'yas-cart',           chart: 'charts/cart',           prefix: 'backend.image'],
            'customer'      : [dir: 'customer',       type: 'java', image: 'yas-customer',       chart: 'charts/customer',       prefix: 'backend.image'],
            'product'       : [dir: 'product',        type: 'java', image: 'yas-product',        chart: 'charts/product',        prefix: 'backend.image'],
            'tax'           : [dir: 'tax',            type: 'java', image: 'yas-tax',            chart: 'charts/tax',            prefix: 'backend.image'],
            'storefront-bff': [dir: 'storefront-bff', type: 'java', image: 'yas-storefront-bff', chart: 'charts/storefront-bff', prefix: 'backend.image'],
            'storefront-ui' : [dir: 'storefront',     type: 'node', image: 'yas-storefront',     chart: 'charts/storefront-ui',  prefix: 'ui.image']
          ]

          def baseCommit = sh(
            script: '''
              if [ -n "$GIT_PREVIOUS_SUCCESSFUL_COMMIT" ]; then
                echo "$GIT_PREVIOUS_SUCCESSFUL_COMMIT"
              else
                git rev-parse HEAD~1 2>/dev/null || true
              fi
            ''',
            returnStdout: true
          ).trim()

          def changedFilesText = ''
          if (baseCommit) {
            changedFilesText = sh(
              script: "git diff --name-only ${baseCommit} HEAD",
              returnStdout: true
            ).trim()
          } else {
            echo "No base commit found. Building all demo services for initial run."
            changedFilesText = serviceConfig.collect { k, v -> "${v.dir}/" }.join('\n')
          }

          def changedFiles = changedFilesText ? changedFilesText.split('\n') : []
          def changed = [] as Set

          changedFiles.each { file ->
            serviceConfig.each { svc, cfg ->
              if (file == cfg.dir || file.startsWith("${cfg.dir}/")) {
                changed.add(svc)
              }
            }

            if (file == 'pom.xml' || file.startsWith('common-library/')) {
              ['cart', 'customer', 'product', 'tax', 'storefront-bff'].each {
                changed.add(it)
              }
            }
          }

          env.CHANGED_SERVICES = changed.join(',')

          echo "Changed files:"
          changedFiles.each { echo " - ${it}" }

          echo "Changed services: ${env.CHANGED_SERVICES ?: 'none'}"
        }
      }
    }

    stage('Prepare Docker Buildx') {
      when {
        expression { env.CHANGED_SERVICES?.trim() }
      }
      steps {
        sh '''
          docker buildx inspect yas-builder >/dev/null 2>&1 || docker buildx create --name yas-builder --use
          docker buildx use yas-builder
          docker buildx inspect --bootstrap
        '''
      }
    }

    stage('Login Docker Hub') {
      when {
        expression { env.CHANGED_SERVICES?.trim() }
      }
      steps {
        withCredentials([usernamePassword(
          credentialsId: env.DOCKERHUB_CREDENTIALS,
          usernameVariable: 'DOCKER_USER',
          passwordVariable: 'DOCKER_PASS'
        )]) {
          sh 'echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin'
        }
      }
    }

    stage('Build And Push Images') {
      when {
        expression { env.CHANGED_SERVICES?.trim() }
      }
      steps {
        script {
          def serviceConfig = [
            'cart'          : [dir: 'cart',           type: 'java', image: 'yas-cart'],
            'customer'      : [dir: 'customer',       type: 'java', image: 'yas-customer'],
            'product'       : [dir: 'product',        type: 'java', image: 'yas-product'],
            'tax'           : [dir: 'tax',            type: 'java', image: 'yas-tax'],
            'storefront-bff': [dir: 'storefront-bff', type: 'java', image: 'yas-storefront-bff'],
            'storefront-ui' : [dir: 'storefront',     type: 'node', image: 'yas-storefront']
          ]

          env.CHANGED_SERVICES.split(',').each { svc ->
            def cfg = serviceConfig[svc]
            def imageRepo = "${env.DOCKERHUB_NAMESPACE}/${cfg.image}"
            def imageTag = env.SHORT_COMMIT

            echo "Building ${svc} -> ${imageRepo}:${imageTag}"

            if (cfg.type == 'java') {
              sh "mvn -B clean package -pl ${cfg.dir} -am -DskipTests"
            }

            sh """
              docker buildx build \
                --platform linux/amd64 \
                -t ${imageRepo}:${imageTag} \
                --push \
                ./${cfg.dir}
            """
          }
        }
      }
    }

    stage('Checkout GitOps Repo') {
      when {
        expression { env.CHANGED_SERVICES?.trim() }
      }
      steps {
        withCredentials([usernamePassword(
          credentialsId: env.GITOPS_CREDENTIALS,
          usernameVariable: 'GIT_USER',
          passwordVariable: 'GIT_TOKEN'
        )]) {
          sh '''
            rm -rf gitops-repo
            set +x
            git clone https://${GIT_USER}:${GIT_TOKEN}@${GITOPS_REPO} gitops-repo
            set -x
          '''
        }
      }
    }

    stage('Update GitOps Dev Tags') {
  when {
    expression { env.CHANGED_SERVICES?.trim() }
  }
  steps {
    dir('gitops-repo') {
      script {
        def gitopsConfig = [
          'cart'          : [file: 'argocd/values/dev/cart.yaml',           root: '.backend.image', image: 'yas-cart'],
          'customer'      : [file: 'argocd/values/dev/customer.yaml',       root: '.backend.image', image: 'yas-customer'],
          'product'       : [file: 'argocd/values/dev/product.yaml',        root: '.backend.image', image: 'yas-product'],
          'tax'           : [file: 'argocd/values/dev/tax.yaml',            root: '.backend.image', image: 'yas-tax'],
          'storefront-bff': [file: 'argocd/values/dev/storefront-bff.yaml', root: '.backend.image', image: 'yas-storefront-bff'],
          'storefront-ui' : [file: 'argocd/values/dev/storefront-ui.yaml',  root: '.ui.image',      image: 'yas-storefront']
        ]

        env.CHANGED_SERVICES.split(',').each { svc ->
          def cfg = gitopsConfig[svc]
          def imageRepo = "${env.DOCKERHUB_NAMESPACE}/${cfg.image}"

          sh """
            IMAGE_REPO='${imageRepo}' \
            IMAGE_TAG='${env.SHORT_COMMIT}' \
            yq -i '${cfg.root}.repository = strenv(IMAGE_REPO) | ${cfg.root}.tag = strenv(IMAGE_TAG)' ${cfg.file}
          """
        }

        sh 'git diff -- argocd/values/dev'
      }
    }
  }
}


    stage('Commit And Push GitOps') {
      when {
        expression { env.CHANGED_SERVICES?.trim() }
      }
      steps {
        dir('gitops-repo') {
          sh """
            git config user.name "jenkins"
            git config user.email "jenkins@example.com"

            if git diff --quiet; then
              echo "No GitOps changes to commit"
              exit 0
            fi

            git add ${GITOPS_FILE}
            git commit -m "Deploy dev images ${SHORT_COMMIT}"
            git push origin ${GITOPS_BRANCH}
          """
        }
      }
    }
  }

  post {
    always {
      sh 'docker logout || true'
    }

    success {
      echo "deploy_dev completed. Services: ${env.CHANGED_SERVICES ?: 'none'}, tag: ${env.SHORT_COMMIT}"
    }

    failure {
      echo "deploy_dev failed. Check the failed stage above."
    }
  }
}
