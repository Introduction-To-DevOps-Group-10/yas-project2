pipeline {
  agent any

  options {
    disableConcurrentBuilds()
    timestamps()
  }

  environment {
    DOCKERHUB_NAMESPACE = 'tunas106'
    DOCKERHUB_CREDENTIALS = 'dockerhub-credentials'
    GITOPS_CREDENTIALS = 'github-token'
    GITOPS_REPO = 'github.com/TUNAS106/yas-gitops.git'
    GITOPS_BRANCH = 'main'
    GITOPS_FILE = 'argocd/applications/yas-dev.yaml'
  }

  stages {
    stage('Checkout Source') {
      steps {
        checkout scm
        script {
          env.SHORT_COMMIT = sh(
            script: 'git rev-parse --short=7 HEAD',
            returnStdout: true
          ).trim()
        }
      }
    }

    stage('Detect Changed Services') {
      steps {
        script {
          def services = [
            'cart'          : [dir: 'cart'],
            'customer'      : [dir: 'customer'],
            'product'       : [dir: 'product'],
            'tax'           : [dir: 'tax'],
            'storefront-bff': [dir: 'storefront-bff'],
            'storefront-ui' : [dir: 'storefront']
          ]

          def baseCommit = sh(
            script: '''
              if [ -n "$GIT_PREVIOUS_SUCCESSFUL_COMMIT" ]; then
                echo "$GIT_PREVIOUS_SUCCESSFUL_COMMIT"
              else
                git rev-parse HEAD~1 2>/dev/null || true
              fi
            ''',
            returnStdout: true
          ).trim()

          def changedFilesText = baseCommit
            ? sh(script: "git diff --name-only ${baseCommit} HEAD", returnStdout: true).trim()
            : sh(script: "git show --pretty='' --name-only HEAD", returnStdout: true).trim()

          def changedFiles = changedFilesText ? changedFilesText.split('\\n') : []
          def changed = [] as Set

          changedFiles.each { file ->
            services.each { name, cfg ->
              if (file == cfg.dir || file.startsWith("${cfg.dir}/")) {
                changed.add(name)
              }
            }

            if (file == 'pom.xml' || file.startsWith('common-library/')) {
              ['cart', 'customer', 'product', 'tax', 'storefront-bff'].each { changed.add(it) }
            }
          }

          env.CHANGED_SERVICES = changed.join(',')
          echo "Changed files: ${changedFiles.join(', ')}"
          echo "Changed services: ${env.CHANGED_SERVICES ?: 'none'}"
        }
      }
    }

    stage('Login Docker Hub') {
      when {
        expression { env.CHANGED_SERVICES?.trim() }
      }
      steps {
        withCredentials([usernamePassword(
          credentialsId: env.DOCKERHUB_CREDENTIALS,
          usernameVariable: 'DOCKER_USER',
          passwordVariable: 'DOCKER_PASS'
        )]) {
          sh 'echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin'
        }
      }
    }

    stage('Build And Push Images') {
      when {
        expression { env.CHANGED_SERVICES?.trim() }
      }
      steps {
        script {
          def serviceConfig = [
            'cart'          : [dir: 'cart',          type: 'java', image: 'yas-cart'],
            'customer'      : [dir: 'customer',      type: 'java', image: 'yas-customer'],
            'product'       : [dir: 'product',       type: 'java', image: 'yas-product'],
            'tax'           : [dir: 'tax',           type: 'java', image: 'yas-tax'],
            'storefront-bff': [dir: 'storefront-bff',type: 'java', image: 'yas-storefront-bff'],
            'storefront-ui' : [dir: 'storefront',    type: 'node', image: 'yas-storefront']
          ]

          env.CHANGED_SERVICES.split(',').each { svc ->
            def cfg = serviceConfig[svc]
            def imageRepo = "${env.DOCKERHUB_NAMESPACE}/${cfg.image}"
            def imageTag = env.SHORT_COMMIT

            if (cfg.type == 'java') {
              sh "mvn -B clean package -pl ${cfg.dir} -am -DskipTests"
            }

            sh """
              docker build -t ${imageRepo}:${imageTag} ./${cfg.dir}
              docker push ${imageRepo}:${imageTag}
            """
          }
        }
      }
    }

    stage('Checkout GitOps Repo') {
      when {
        expression { env.CHANGED_SERVICES?.trim() }
      }
      steps {
        withCredentials([usernamePassword(
          credentialsId: env.GITOPS_CREDENTIALS,
          usernameVariable: 'GIT_USER',
          passwordVariable: 'GIT_TOKEN'
        )]) {
          sh '''
            rm -rf gitops-repo
            set +x
            git clone https://${GIT_USER}:${GIT_TOKEN}@${GITOPS_REPO} gitops-repo
            set -x
          '''
        }
      }
    }

    stage('Update GitOps Dev Image Tags') {
      when {
        expression { env.CHANGED_SERVICES?.trim() }
      }
      steps {
        dir('gitops-repo') {
          script {
            def gitopsConfig = [
              'cart'          : [chart: 'charts/cart',          prefix: 'backend.image', image: 'yas-cart'],
              'customer'      : [chart: 'charts/customer',      prefix: 'backend.image', image: 'yas-customer'],
              'product'       : [chart: 'charts/product',       prefix: 'backend.image', image: 'yas-product'],
              'tax'           : [chart: 'charts/tax',           prefix: 'backend.image', image: 'yas-tax'],
              'storefront-bff': [chart: 'charts/storefront-bff',prefix: 'backend.image', image: 'yas-storefront-bff'],
              'storefront-ui' : [chart: 'charts/storefront-ui', prefix: 'ui.image',      image: 'yas-storefront']
            ]

            env.CHANGED_SERVICES.split(',').each { svc ->
              def cfg = gitopsConfig[svc]
              def imageRepo = "${env.DOCKERHUB_NAMESPACE}/${cfg.image}"

              sh """
                CHART_PATH='${cfg.chart}' \
                IMAGE_PREFIX='${cfg.prefix}' \
                IMAGE_REPO='${imageRepo}' \
                IMAGE_TAG='${env.SHORT_COMMIT}' \
                yq -i 'with(.spec.sources[] | select(.path == strenv(CHART_PATH)) | .helm.parameters;
                  . = ((. // [])
                    | map(select(.name != strenv(IMAGE_PREFIX) + ".repository" and .name != strenv(IMAGE_PREFIX) + ".tag"))
                    + [
                        {"name": strenv(IMAGE_PREFIX) + ".repository", "value": strenv(IMAGE_REPO)},
                        {"name": strenv(IMAGE_PREFIX) + ".tag", "value": strenv(IMAGE_TAG)}
                      ])
                )' ${env.GITOPS_FILE}
              """
            }

            sh "git diff -- ${env.GITOPS_FILE}"
          }
        }
      }
    }

    stage('Commit And Push GitOps') {
      when {
        expression { env.CHANGED_SERVICES?.trim() }
      }
      steps {
        dir('gitops-repo') {
          sh """
            git config user.name "jenkins"
            git config user.email "jenkins@example.com"

            if git diff --quiet; then
              echo "No GitOps changes to commit"
              exit 0
            fi

            git add ${GITOPS_FILE}
            git commit -m "Deploy dev images ${SHORT_COMMIT}"
            git push origin ${GITOPS_BRANCH}
          """
        }
      }
    }
  }

  post {
    always {
      sh 'docker logout || true'
    }
    success {
      echo "Done. Services: ${env.CHANGED_SERVICES ?: 'none'}, tag: ${env.SHORT_COMMIT}"
    }
  }
}
